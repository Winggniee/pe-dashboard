# 飞书应用凭证
FEISHU_APP_ID=你的应用ID
FEISHU_APP_SECRET=你的应用密钥

# 服务器配置
PORT=3001

# 同步间隔（分钟）
SYNC_INTERVAL=1

# 要同步的多维表格 ID（支持格式：appToken 或 appToken:tableId，多个用逗号分隔）
# 示例：FEISHU_BITABLE_IDS=bascnxxxxxx,bascnxxxxxx
FEISHU_BITABLE_IDS=

# PE 项目甘特图专用数据源（变更历史记录表，与上面的 FEISHU_BITABLE_IDS 可以是不同的多维表格）
# 若表格是通过 Wiki 链接打开的（形如 https://xxx.feishu.cn/wiki/<NODE_TOKEN>?table=<TABLE_ID>），
# 需要填写下面两个值；FEISHU_GANTT_WIKI_NODE 用于解析出真实的 app_token
FEISHU_GANTT_WIKI_NODE=
FEISHU_GANTT_TABLE_ID=
