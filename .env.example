# 飞书应用凭证
FEISHU_APP_ID=你的应用ID
FEISHU_APP_SECRET=你的应用密钥

# 服务器配置
PORT=3001

# 同步间隔（分钟）
SYNC_INTERVAL=1

# 要同步的文档/表格 ID（用逗号分隔）
# 示例：FEISHU_DOCUMENT_IDS=doxcnxxxxxx,doxcnxxxxxx
# 示例：FEISHU_SHEET_IDS=shtcnxxxxxx,shtcnxxxxxx
# 示例：FEISHU_WIKI_IDS=KLivwayNai46IYk7ZQicUSsxn9e
# 示例：FEISHU_BITABLE_IDS=bascnxxxxxx,bascnxxxxxx
FEISHU_DOCUMENT_IDS=
FEISHU_SHEET_IDS=
FEISHU_WIKI_IDS=
FEISHU_BITABLE_IDS=
